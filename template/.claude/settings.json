{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "marketplaces": {
    "claudy-marketplace": {
      "source": "github",
      "repo": "gilles-bertrand/claudy-marketplace"
    }
  },
  "plugins": {
    "claudy@claudy-marketplace": {
      "enabled": true
    }
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Read(.env)"
    ]
  }
}
